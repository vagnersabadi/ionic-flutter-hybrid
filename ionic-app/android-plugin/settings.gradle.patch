// =============================================================
// PATCH: android/settings.gradle
// Adicione estas linhas ao final do arquivo settings.gradle
// para integrar o Flutter module no build Android.
// =============================================================

// Integra o Flutter module (Add-to-App)
setBinding(new Binding([gradle: this]))
evaluate(new File(
    settingsDir,
    '../flutter_module/.android/include_flutter.groovy'
))

// Inclui o modulo Flutter como dependencia
include ':flutter_module'
project(':flutter_module').projectDir = new File('../flutter_module')
